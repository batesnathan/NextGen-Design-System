{
  "name": "nextgen-design-system",
  "version": "0.1.0",
  "private": false,
  "description": "AI-first design system with primitives, semantic tokens, and TSX components.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/tokens/source",
    "src/tokens/generated",
    "docs"
  ],
  "scripts": {
    "sync:tokens": "node ./scripts/sync-figma-tokens.mjs",
    "build:tokens": "node ./scripts/build-tokens.mjs",
    "build": "npm run build:tokens && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "validate:design": "npm run check && npm run build-storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "keywords": [
    "design-system",
    "tokens",
    "ai",
    "tsx",
    "vibe-coding"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.12",
    "typescript": "^5.8.2",
    "storybook": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-onboarding": "^10.2.19",
    "vitest": "^4.1.0",
    "playwright": "^1.58.2",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  }
}
